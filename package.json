{
  "name": "tanstack-starter",
  "version": "1.0.0",
  "description": "TanStack Start frontend starter — SSR, streaming, Tailwind v4, Base UI, auth-ready",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint app/",
    "format": "prettier --write 'app/**/*.{ts,tsx,css}'",
    "format:check": "prettier --check 'app/**/*.{ts,tsx,css}'",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "ci": "pnpm lint && pnpm format:check && pnpm typecheck && pnpm test -- run"
  },
  "keywords": [
    "tanstack",
    "react",
    "starter",
    "tailwindcss"
  ],
  "author": "Addison Enterprises",
  "license": "MIT",
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": "^11.5.0",
      "onFail": "download"
    }
  },
  "dependencies": {
    "@tanstack/react-query": "^5.101.2",
    "@tanstack/react-router": "^1.170.17",
    "@tanstack/react-start": "^1.168.27",
    "@vitejs/plugin-react": "^6.0.3",
    "better-auth": "^1.6.23",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "vite": "^8.1.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@base-ui/react": "^1.6.0",
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.3.2",
    "@tanstack/react-query-devtools": "^5.101.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^26.1.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "eslint": "^10.6.0",
    "jsdom": "^29.1.1",
    "prettier": "^3.9.4",
    "tailwindcss": "^4.3.2",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.63.0",
    "vinxi": "^0.5.11",
    "vitest": "^4.1.10"
  }
}
